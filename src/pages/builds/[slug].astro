---
import { projects } from '../../data/projects';

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={`${project.title}: ${project.scope}`} />
    <title>{project.title} — M</title>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <div class="terminal-shell">
      <div class="terminal-titlebar" aria-hidden="true">
        <span>m@portfolio:~/builds/{project.slug}</span>
        <span>TTY 01 · BUILD DETAIL</span>
      </div>
      <header class="site-header">
        <a class="wordmark" href="/" aria-label="M home">M<span>_</span></a>
        <a class="back-link" href="/#work">← back to builds</a>
      </header>

      <main id="main">
        <section class="detail-hero" aria-labelledby="build-title">
          <p class="eyebrow">{project.type}</p>
          <h1 id="build-title">{project.title}</h1>
          <p class="lede">{project.description}</p>
        </section>

        <section class="detail-grid" aria-label={`${project.title} details`}>
          <div class="detail-block">
            <p class="detail-label">$ scope</p>
            <p>{project.scope}</p>
          </div>
          <div class="detail-block">
            <p class="detail-label">$ stack</p>
            <p>{project.stack}</p>
            <p class="status">status: {project.status}</p>
          </div>
        </section>

        <section class="features" aria-labelledby="features-title">
          <p class="detail-label">$ ls features</p>
          <h2 id="features-title">What it does</h2>
          <ul>
            {project.features.map((feature: string) => <li>{feature}</li>)}
          </ul>
        </section>

        <div class="detail-actions">
          <a class="primary-link" href={project.href}>{project.linkLabel} ↗</a>
          <a class="back-link" href="/#work">← back to builds</a>
        </div>
      </main>

      <footer class="site-footer">
        <p>© {new Date().getFullYear()} M</p>
        <p>static build detail</p>
      </footer>
    </div>
  </body>
</html>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Fascinate+Inline&family=IBM+Plex+Mono:wght@400;500;600&family=Silkscreen:wght@400;700&family=VT323&display=swap');

  :global(*) { box-sizing: border-box; }
  :global(html) { scroll-behavior: smooth; }
  :global(body) { margin: 0; background: #11111b; color: #cdd6f4; font-family: 'IBM Plex Mono', monospace; font-size: 16px; line-height: 1.6; }
  :global(a) { color: inherit; }
  :global(a:focus-visible) { outline: 3px solid #f9e2af; outline-offset: 5px; }
  .skip-link { position: absolute; left: 1rem; top: -4rem; padding: .65rem 1rem; background: #313244; color: #cdd6f4; z-index: 10; }
  .skip-link:focus { top: 1rem; }
  .terminal-shell { position: relative; max-width: 1220px; margin: 1.5rem auto; background: #1e1e2e; border: 1px solid #7f849c; box-shadow: inset 0 0 0 4px #181825, inset 0 0 0 5px #45475a, 8px 8px 0 #11111b; overflow: hidden; }
  .terminal-shell::after { position: absolute; inset: 0; z-index: 5; pointer-events: none; content: ''; opacity: .045; background: repeating-linear-gradient(0deg, transparent 0 3px, #cdd6f4 3px 4px); }
  .terminal-titlebar { display: flex; justify-content: space-between; gap: 1rem; padding: .55rem 1.25rem; background: #313244; border-bottom: 1px solid #7f849c; color: #f9e2af; font-size: .7rem; letter-spacing: .04em; }
  .site-header, main, .site-footer { max-width: 1180px; margin: 0 auto; padding-left: 2rem; padding-right: 2rem; }
  .site-header { display: flex; justify-content: space-between; align-items: center; padding-top: 1.4rem; padding-bottom: 1.1rem; border-bottom: 1px solid #45475a; }
  .wordmark { font-size: 1.45rem; font-weight: 600; text-decoration: none; letter-spacing: .08em; }
  .wordmark span { color: #a6e3a1; }
  .back-link { color: #a6adc8; font-size: .78rem; text-decoration: none; }
  .back-link:hover { color: #a6e3a1; }
  .detail-hero { padding: clamp(5rem, 12vw, 9rem) 0 5rem; border-bottom: 1px solid #45475a; }
  .eyebrow, .detail-label { margin: 0 0 1rem; color: #a6e3a1; font-size: .72rem; font-weight: 500; letter-spacing: .08em; text-transform: uppercase; }
  .eyebrow::before, .detail-label::before { content: '> '; color: #f9e2af; }
  h1, h2 { font-family: 'Fascinate Inline', cursive; font-weight: 400; }
  h1 { max-width: 900px; margin: 0 0 2rem; color: #a6e3a1; font-size: clamp(3rem, 8vw, 7rem); line-height: 1; }
  .lede { max-width: 700px; margin: 0; color: #a6adc8; font-size: 1.1rem; }
  .detail-grid { display: grid; grid-template-columns: 1.2fr .8fr; gap: 1rem; padding: 3rem 0; border-bottom: 1px solid #45475a; }
  .detail-block { padding: 1.25rem; border: 1px solid #45475a; background: #11111b; box-shadow: inset 0 0 0 1px #181825; }
  .detail-block p:last-child { margin-bottom: 0; }
  .status { color: #f9e2af; font-family: 'VT323', monospace; font-size: 1.1rem; }
  .features { padding: 4rem 0; }
  h2 { margin: 0 0 2rem; color: #cdd6f4; font-size: clamp(2rem, 5vw, 4rem); }
  ul { max-width: 760px; margin: 0; padding: 0; list-style: none; }
  li { padding: .9rem 0 .9rem 2rem; border-top: 1px dashed #45475a; color: #a6adc8; }
  li::before { margin-left: -2rem; margin-right: 1rem; content: '>'; color: #a6e3a1; }
  .detail-actions { display: flex; align-items: center; gap: 2rem; padding-bottom: 6rem; }
  .primary-link { padding: .8rem 1rem; border: 1px solid #a6e3a1; color: #a6e3a1; text-decoration: none; }
  .primary-link:hover { background: #313244; }
  .site-footer { display: flex; justify-content: space-between; padding-top: 1.5rem; padding-bottom: 2rem; color: #7f849c; font-size: .68rem; }
  .site-footer p { margin: 0; }
  @media (max-width: 700px) {
    .terminal-shell { margin: .5rem; box-shadow: inset 0 0 0 3px #181825, inset 0 0 0 4px #45475a, 4px 4px 0 #11111b; }
    .terminal-titlebar { padding-left: .8rem; padding-right: .8rem; font-size: .6rem; }
    .site-header, main, .site-footer { padding-left: 1.25rem; padding-right: 1.25rem; }
    .detail-grid { grid-template-columns: 1fr; }
    .detail-actions { align-items: flex-start; flex-direction: column; gap: 1.25rem; }
    .site-footer { display: block; }
    .site-footer p + p { margin-top: .5rem; }
  }
</style>
