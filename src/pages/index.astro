---
const projects = [
  {
    title: 'Sift',
    type: 'Research infrastructure',
    description: 'A local research engine that searches, crawls, indexes, and synthesizes the web while keeping the material close at hand.',
    stack: 'Python · SQLite FTS5 · LLM APIs',
    href: 'https://github.com/gh0stprince/sift',
    linkLabel: 'View project'
  },
  {
    title: 'Scribble',
    type: 'Creative tools',
    description: 'A handwriting-to-text system built around drawing, on-device recognition, local persistence, and offline-friendly work.',
    stack: 'TypeScript · Go · Tesseract.js · PWA',
    href: 'https://github.com/gh0stprince',
    linkLabel: 'Private build'
  },
  {
    title: 'Contract Autopsy',
    type: 'On-chain tooling',
    description: 'A plain-English post-mortem for ERC-721 contracts, turning on-chain state into a report people can actually read.',
    stack: 'TypeScript · OpenSea SDK · Base',
    href: 'https://github.com/gh0stprince',
    linkLabel: 'Private build'
  },
  {
    title: 'Inn Protocol',
    type: 'Protocol design',
    description: 'An agent-first application protocol for communication across a trusted private network, with a formal specification and reference implementation.',
    stack: 'Python · TCP · WireGuard · 333 tests',
    href: 'https://github.com/gh0stprince',
    linkLabel: 'Local build'
  }
];
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="M is a developer building tools for thoughtful work: terminal interfaces, writing systems, research infrastructure, and live agent experiences." />
    <title>M — Developer, builder, systems thinker</title>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <header class="site-header">
      <a class="wordmark" href="/" aria-label="M home">M<span>.</span></a>
      <nav aria-label="Primary navigation">
        <a href="#work">Work</a>
        <a href="#about">About</a>
        <a href="#contact">Contact</a>
      </nav>
    </header>

    <main id="main">
      <section class="hero" aria-labelledby="hero-title">
        <p class="eyebrow">Developer · builder · systems thinker</p>
        <h1 id="hero-title">I make tools that help people <em>think, make, and stay.</em></h1>
        <div class="hero-bottom">
          <p class="hero-copy">I am Melora, a visual artist and developer working across interfaces, infrastructure, and the strange spaces between them. My projects are usually small acts of care: make the system clearer, make the work more possible, leave a better path behind.</p>
          <a class="text-link" href="#work">See selected work <span aria-hidden="true">↓</span></a>
        </div>
      </section>

      <section id="work" class="work-section" aria-labelledby="work-title">
        <div class="section-heading">
          <p class="eyebrow">Selected work</p>
          <h2 id="work-title">Builds</h2>
        </div>
        <div class="project-list">
          {projects.map((project) => (
            <article class="project-row">
              <div class="project-terminal-bar">
                <span>~/builds/{project.title.toLowerCase().replaceAll(' ', '-')}</span>
                <span>{project.linkLabel}</span>
              </div>
              <span class="project-number" aria-hidden="true">›</span>
              <div class="project-main">
                <p class="project-type">{project.type}</p>
                <h3><a href={project.href}>{project.title}</a></h3>
                <p class="project-description">{project.description}</p>
              </div>
              <div class="project-meta">
                <p>{project.stack}</p>
                <a class="arrow-link" href={project.href} aria-label={`${project.linkLabel}: ${project.title}`}>{project.linkLabel} <span aria-hidden="true">↗</span></a>
              </div>
            </article>
          ))}
        </div>
      </section>

      <section id="about" class="about-section" aria-labelledby="about-title">
        <div class="section-heading">
          <p class="eyebrow">A little context</p>
          <h2 id="about-title">Useful things should still feel alive.</h2>
        </div>
        <div class="about-copy">
          <p>I care about software that respects attention. That means interfaces with a point of view, systems that explain themselves, and automation that leaves people more capable rather than more dependent.</p>
          <p>These days I am especially interested in local-first tools, agent interfaces, research workflows, and the craft of making complicated systems feel inhabitable.</p>
        </div>
      </section>

      <section id="contact" class="contact-section" aria-labelledby="contact-title">
        <p class="eyebrow">Start a conversation</p>
        <h2 id="contact-title">Have a difficult system<br /><em>worth making clearer?</em></h2>
        <a class="contact-link" href="mailto:admin@servitor.love">admin@servitor.love <span aria-hidden="true">↗</span></a>
      </section>
    </main>

    <footer class="site-footer">
      <p>© {new Date().getFullYear()} M</p>
      <p>Built with Astro · deployed on GitHub Pages</p>
    </footer>
  </body>
</html>

<style>
  @import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&display=swap');

  :global(*) { box-sizing: border-box; }
  :global(html) { scroll-behavior: smooth; }
  :global(body) { margin: 0; background: #1e1e2e; color: #cdd6f4; font-family: 'IBM Plex Mono', monospace; font-size: 16px; line-height: 1.6; }
  :global(a) { color: inherit; }
  :global(a:focus-visible) { outline: 3px solid #f9e2af; outline-offset: 5px; }
  .skip-link { position: absolute; left: 1rem; top: -4rem; padding: .65rem 1rem; background: #313244; color: #cdd6f4; z-index: 10; }
  .skip-link:focus { top: 1rem; }
  .site-header, .site-footer, main { max-width: 1180px; margin: 0 auto; padding-left: 2rem; padding-right: 2rem; }
  .site-header { display: flex; justify-content: space-between; align-items: center; padding-top: 1.75rem; padding-bottom: 1.1rem; border-bottom: 1px solid #45475a; }
  .wordmark { font-size: 2rem; font-weight: 600; text-decoration: none; letter-spacing: -.1em; }
  .wordmark span { color: #a6e3a1; }
  nav { display: flex; gap: 1.5rem; font-size: .78rem; }
  nav a { text-decoration: none; }
  nav a:hover, nav a:focus-visible, .text-link:hover, .arrow-link:hover { color: #a6e3a1; }
  .hero { padding: clamp(6rem, 16vw, 12rem) 0 clamp(6rem, 13vw, 10rem); border-bottom: 1px solid #45475a; }
  .eyebrow, .project-type { margin: 0; color: #a6e3a1; font-size: .72rem; font-weight: 500; letter-spacing: .08em; text-transform: uppercase; }
  .eyebrow::before { content: '> '; color: #f9e2af; }
  h1, h2, h3, p { margin-top: 0; }
  h1 { max-width: 1000px; margin: 1.2rem 0 3rem; font-size: clamp(2.8rem, 7.6vw, 6.8rem); line-height: 1.02; letter-spacing: -.075em; font-weight: 600; }
  h1 em, h2 em { color: #a6e3a1; font-style: normal; }
  .hero-bottom { display: grid; grid-template-columns: minmax(0, 420px) auto; gap: 3rem; align-items: end; }
  .hero-copy { margin: 0; font-size: 1.05rem; }
  .text-link, .arrow-link, .contact-link { font-weight: 700; text-decoration-thickness: 1px; text-underline-offset: .35em; }
  .work-section, .about-section { padding: 5.5rem 0; border-bottom: 1px solid #45475a; }
  .section-heading { display: grid; grid-template-columns: 180px minmax(0, 1fr); gap: 2rem; margin-bottom: 3rem; }
  h2 { max-width: 700px; margin: 0; font-size: clamp(2rem, 4.8vw, 4.5rem); letter-spacing: -.07em; line-height: 1.08; font-weight: 600; }
  .project-row { display: grid; grid-template-columns: 35px minmax(0, 1fr) minmax(160px, 220px); gap: 1.5rem; margin-top: 1rem; padding: 0 1.5rem 1.5rem; border: 1px solid #45475a; background: #181825; }
  .project-terminal-bar { grid-column: 1 / -1; display: flex; justify-content: space-between; gap: 1rem; padding: .7rem 0; border-bottom: 1px solid #313244; color: #7f849c; font-size: .72rem; }
  .project-terminal-bar span:last-child { color: #a6e3a1; }
  .project-number { color: #f9e2af; padding-top: .1rem; font-size: 1.2rem; }
  .project-main h3 { margin: .35rem 0 .7rem; font-size: clamp(1.7rem, 3vw, 2.5rem); letter-spacing: -.05em; }
  .project-main h3 a { text-decoration: none; }
  .project-main h3 a:hover { color: #a6e3a1; }
  .project-description { max-width: 570px; margin-bottom: 0; color: #a6adc8; }
  .project-meta { display: flex; flex-direction: column; justify-content: space-between; gap: 1rem; color: #a6adc8; font-size: .73rem; }
  .project-meta p { margin: 0; }
  .arrow-link { color: #cdd6f4; font-size: .85rem; }
  .about-section { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; }
  .about-copy { max-width: 540px; font-size: 1.1rem; }
  .about-copy p + p { margin-top: 1.5rem; }
  .contact-section { padding: 9rem 0 10rem; }
  .contact-section h2 { margin: 1rem 0 2.5rem; }
  .contact-link { font-size: clamp(1rem, 2vw, 1.35rem); }
  .site-footer { display: flex; justify-content: space-between; padding-top: 1.5rem; padding-bottom: 2rem; color: #7f849c; font-size: .68rem; }
  .site-footer p { margin: 0; }
  @media (max-width: 700px) {
    .site-header, .site-footer, main { padding-left: 1.25rem; padding-right: 1.25rem; }
    nav { gap: .8rem; font-size: .68rem; }
    .hero { padding-top: 6rem; }
    .hero-bottom, .about-section { grid-template-columns: 1fr; gap: 2rem; }
    .section-heading { display: block; }
    .section-heading .eyebrow { margin-bottom: 1.3rem; }
    .project-row { grid-template-columns: 25px minmax(0, 1fr); gap: .85rem; padding-left: 1rem; padding-right: 1rem; }
    .project-terminal-bar { font-size: .65rem; }
    .project-meta { grid-column: 2; gap: 1.3rem; }
    .site-footer { display: block; }
    .site-footer p + p { margin-top: .5rem; }
  }
  @media (prefers-reduced-motion: reduce) { :global(html) { scroll-behavior: auto; } }
</style>
